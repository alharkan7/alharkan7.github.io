---
export const prerender = false;

import { resolveTweetsPage } from "../lib/tweets-query";
import TweetsPage from "../components/tweets/TweetsPage.astro";

const resolved = await resolveTweetsPage(Astro.url, Astro.site, 1);
if ("redirectTo" in resolved) return Astro.redirect(resolved.redirectTo);

const searchRaw = Astro.url.searchParams.get("search") ?? "";
if (!searchRaw) {
  Astro.response.headers.set(
    "Cache-Control",
    "s-maxage=300, stale-while-revalidate=3600",
  );
}
---

<TweetsPage view={resolved.view} />
