---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { Analytics } from "@vercel/analytics/react";
import { SpeedInsights } from "@vercel/speed-insights/react";

export interface Props {
  title: string;
  description: string;
  permalink: string;
  current?: string;
  image?: string;
  subtitle?: string;
  type?: "website" | "article" | "collection";
  publishDate?: string;
  items?: Array<{ name: string; url?: string; description?: string }>;
}
const {
  title,
  description,
  permalink,
  current,
  image,
  subtitle,
  type = "website",
  publishDate,
  items,
} = Astro.props;

// Protected Routes Logic
const currentPath = Astro.url.pathname;
// Remove trailing slash for consistent matching
const normalizedPath = currentPath.endsWith('/') && currentPath.length > 1 ? currentPath.slice(0, -1) : currentPath;

const protectedRoutesStr = import.meta.env.NEXT_PUBLIC_PROTECTED_ROUTES || import.meta.env.PUBLIC_PROTECTED_ROUTES || "";
const protectedRoutes = protectedRoutesStr.split(',').map((r: string) => r.trim()).filter(Boolean);

const isProtected = protectedRoutes.some((route: string) => {
  const normalizedRoute = route.endsWith('/') && route.length > 1 ? route.slice(0, -1) : route;
  return normalizedPath === normalizedRoute || normalizedPath.startsWith(normalizedRoute + '/');
});
---

<html lang="en">
  <head>
    <BaseHead
      title={title === "Al Harkan's Blog" ? title : `${title}`}
      description={description}
      permalink={permalink}
      image={image}
      subtitle={subtitle}
      type={type}
      publishDate={publishDate}
      items={items}
    />
    <script src="https://accounts.google.com/gsi/client" async defer></script>
  </head>
  <body>
    {isProtected && (
      <div id="auth-guard-loading" class="fixed inset-0 z-[100] flex items-center justify-center bg-white dark:bg-gray-900">
        <div class="text-center bg-gray-50 dark:bg-[#070A12] p-8 rounded-2xl shadow-xl max-w-sm w-full mx-4 border border-gray-100 dark:border-gray-800">
          <div id="auth-spinner" class="inline-block animate-spin rounded-full h-12 w-12 border-t-2 border-b-2 border-gray-900 dark:border-white mb-4"></div>
          <h2 id="auth-title" class="text-2xl font-bold text-gray-800 dark:text-white">Verifying access</h2>
          <p id="auth-subtitle" class="text-gray-600 dark:text-gray-400 mt-2 mb-6">Checking your session...</p>
          <div id="google-btn-container" class="flex justify-center min-h-[44px]" style="display: none;"></div>
        </div>
      </div>
    )}
    <div class="layout" style={isProtected ? "visibility: hidden;" : ""}>
      <Header current={current} />

      <main>
        <slot />
      </main>

      <Footer />
    </div>
    <Analytics client:only="react" />
    <SpeedInsights client:only="react" />

    <script>
      import { supabase } from '../lib/supabase';
      
      const checkAuth = async () => {
        const loadingScreen = document.getElementById('auth-guard-loading');
        const layout = document.querySelector('.layout') as HTMLElement;
        const spinner = document.getElementById('auth-spinner');
        const title = document.getElementById('auth-title');
        const subtitle = document.getElementById('auth-subtitle');
        const btnContainer = document.getElementById('google-btn-container');
        
        if (loadingScreen) {
          // Verify session via Supabase
          const { data: { session }, error } = await supabase.auth.getSession();
          
          if (!session) {
            // Show the login UI
            if (spinner) spinner.style.display = 'none';
            if (title) title.innerText = 'Authentication Required';
            if (subtitle) subtitle.innerText = 'Please sign in to view this page.';
            if (btnContainer) btnContainer.style.display = 'flex';
            
            const clientId = import.meta.env.NEXT_PUBLIC_GOOGLE_CLIENT_ID || import.meta.env.PUBLIC_GOOGLE_CLIENT_ID;
            
            const initGoogle = () => {
              const google = (window as any).google;
              google.accounts.id.initialize({
                client_id: clientId,
                callback: async (response: any) => {
                  // Re-show loading state while saving to Supabase
                  if (btnContainer) btnContainer.style.display = 'none';
                  if (spinner) spinner.style.display = 'inline-block';
                  if (title) title.innerText = 'Signing you in...';
                  if (subtitle) subtitle.innerText = 'Establishing secure session';
                  
                  // Send the Google ID token to Supabase
                  const { error: signInError } = await supabase.auth.signInWithIdToken({
                    provider: 'google',
                    token: response.credential
                  });
                  
                  if (signInError) {
                    console.error("Error linking Google to Supabase:", signInError);
                    if (title) title.innerText = 'Login Error';
                    if (subtitle) subtitle.innerHTML = '<span class="text-red-500">Could not save session. Try again.</span>';
                    if (spinner) spinner.style.display = 'none';
                    if (btnContainer) btnContainer.style.display = 'flex';
                  } else {
                    // Authenticated! Show the content
                    loadingScreen.style.display = 'none';
                    if (layout) layout.style.visibility = 'visible';
                  }
                }
              });
              
              // Render the native Google button
              google.accounts.id.renderButton(btnContainer, { 
                theme: 'outline', 
                size: 'large',
                shape: 'rectangular',
                text: 'signin_with'
              });
            };

            // Wait for the Google script to be available
            if ((window as any).google?.accounts?.id) {
              initGoogle();
            } else {
              const checkInterval = setInterval(() => {
                if ((window as any).google?.accounts?.id) {
                  clearInterval(checkInterval);
                  initGoogle();
                }
              }, 100);
            }
          } else {
            // Authenticated! Show the content
            loadingScreen.style.display = 'none';
            if (layout) layout.style.visibility = 'visible';
          }
        }
      };

      // Run immediately for normal page loads
      checkAuth();
      
      // Also run on Astro view transitions navigation
      document.addEventListener('astro:page-load', checkAuth);
    </script>
  </body>
</html>

<style>
  .layout {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    min-height: 100vh;
  }

  /* Style the header to be sticky */
  .layout > :global(header) {
    /* Target header rendered by Header component */
    position: sticky;
    top: 0;
    z-index: 10; /* Ensure it stays on top */
    /* Add a background color to prevent content showing through */
    /* You might want to adjust this color to match your theme */
    background-color: var(--background-header);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    /* Optional: Add a border or shadow for visual separation */
    /* border-bottom: 1px solid var(--color-border, #e0e0e0); */
  }

  main {
    flex: 1;
    position: relative;
    margin: 0 auto;
    max-width: 1400px;
    padding: 1em 2em;
    box-sizing: border-box;
    width: 100%;
    display: flex;
    flex-direction: column;
  }
</style>
